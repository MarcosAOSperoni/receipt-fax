[Unit]
Description=Receipt Fax Printer Client
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/receipt-fax/printer
ExecStart=/home/YOUR_USER/receipt-fax/printer/.venv/bin/python /home/YOUR_USER/receipt-fax/printer/client.py /home/YOUR_USER/receipt-fax/printer/config.ini
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
